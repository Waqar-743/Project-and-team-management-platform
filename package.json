{
  "name": "forge-task-platform",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && tsx prisma/bootstrap.ts && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:bootstrap": "tsx prisma/bootstrap.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "@prisma/client": "^6.11.1",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.11",
    "next": "^15.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.4.1",
    "prisma": "^6.11.1",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
